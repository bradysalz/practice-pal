<div class="table-container">
    <table class="table">
        <thead>
            <th>User</th>
            <th>Exercise</th>
            <th>Time</th>
            <th>Tempo</th>
            <th>Notes</th>
        </thead>
        <tbody>
            {{#each practices}}
                <tr>
                    <td>{{this.user_id}}</td>
                    <td>{{this.exercise_id}}</td>
                    <td>{{this.done_at}}</td>
                    <td>{{this.tempo}}</td>
                    <td>{{this.note}}</td>
                </tr>
            {{/each}}
        </tbody>
    </table>
</div>
